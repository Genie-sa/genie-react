{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@genie-react/core": ["./packages/core/src/index.ts"],
      "@genie-react/bridge": ["./packages/bridge/src/index.ts"],
      "@genie-react/client": ["./packages/client/src/index.ts"],
      "@genie-react/vite": ["./packages/vite/src/index.ts"],
      "@genie-react/react-collector": ["./packages/react-collector/src/index.ts"],
      "@genie-react/tanstack-collector": ["./packages/tanstack-collector/src/index.ts"],
      "@genie-react/devtools-plugin": ["./packages/devtools-plugin/src/index.ts"],
      "@genie-react/memory": ["./packages/memory/src/index.ts"],
      "@genie-react/cli": ["./packages/cli/src/index.ts"],
      "@genie-react/react": ["./packages/react/src/index.ts"]
    },
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noEmit": true
  }
}
