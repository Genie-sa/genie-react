{
  "name": "@genie-react/react-collector",
  "version": "0.1.0",
  "description": "React fiber collector for Genie: component tree, inspect props/state/hooks, via bippy.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y0u-0/genie-react.git",
    "directory": "packages/react-collector"
  },
  "homepage": "https://github.com/y0u-0/genie-react-agent#readme",
  "bugs": "https://github.com/y0u-0/genie-react-agent/issues",
  "keywords": [
    "react",
    "tanstack",
    "devtools",
    "ai-agent",
    "claude",
    "bippy",
    "profiler",
    "why-did-render"
  ],
  "author": "y0u-0",
  "type": "module",
  "sideEffects": [
    "./dist/hook.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hook": {
      "types": "./dist/hook.d.ts",
      "import": "./dist/hook.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@genie-react/client": "workspace:*",
    "@genie-react/core": "workspace:*",
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "bippy": "^0.5.42",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
