{
  "name": "@genie-react/react",
  "version": "0.1.0",
  "description": "One-line <Genie /> integration for React + TanStack apps.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y0u-0/genie-react.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/y0u-0/genie-react-agent#readme",
  "bugs": "https://github.com/y0u-0/genie-react-agent/issues",
  "keywords": [
    "react",
    "tanstack",
    "devtools",
    "ai-agent",
    "claude",
    "vite"
  ],
  "author": "y0u-0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@genie-react/client": "workspace:*",
    "@genie-react/core": "workspace:*",
    "@genie-react/devtools-plugin": "workspace:*",
    "@genie-react/memory": "workspace:*",
    "@genie-react/react-collector": "workspace:*",
    "@genie-react/tanstack-collector": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "@tanstack/react-router": ">=1",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^28.1.0",
    "react": "^19.2.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
